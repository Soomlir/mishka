{% extends '../common/layout.twig' %}

{% set isMain = false %}

{% block main %}
	<main class="page-main">
		<section class="page-main__filters filters">
			<h1 class="filters__heading">Вязание на заказ</h1>
			<p class="filters__text">
				Мы будем рады воплотить в жизнь ваши пожелания! Заполните простую форму заказа
				и мы свяжемся с вами, чтобы уточнить детали.
			</p>
			<form class="filters__form" method="post" action="https://echo.htmlacademy.ru">
				<fieldset class="filters__fieldset">
					<legend>Тип</legend>
					<label for="accessories">Аксессуар для интерьера</label>
					<input id="accessories" type="radio" name="type" checked>
					<label for="toy">Детская игрушка</label>
					<input id="toy" type="radio" name="type">
				</fieldset>

				<fieldset class="filters__fieldset">
					<legend>Цвет</legend>
					<label for="color1">Белый</label>
					<input id="color1" type="checkbox" name="color" checked>
					<label for="color2">Серый</label>
					<input id="color2" type="checkbox" name="color" checked>
					<label for="color3">Тиффани</label>
					<input id="color3" type="checkbox" name="color">
					<label for="color4">Черный</label>
					<input id="color4" type="checkbox" name="color">
					<label for="color5">Розовый</label>
					<input id="color5" type="checkbox" name="color">
					<label for="color6">Оранжевый</label>
					<input id="color6" type="checkbox" name="color">
				</fieldset>

				<fieldset class="filters__fieldset">
					<legend>Фио</legend>
					<label for="name">Имя:</label>
					<input id="name" type="text" name="name" placeholder="Введите ваше имя*">
					<label for="last-name">Фамилия:</label>
					<input id="last-name" type="text" name="last-name" placeholder="Укажите фамилию*">
					<label for="patronymic">Отчество:</label>
					<input id="patronymic" type="text" name="patronymic" placeholder="Отчество, если желаете">
				</filedset>

				<fieldset class="filters__fieldset">
					<legend>Тел</legend>
					<input type="tel" name="tel" placeholder="+7 ХХХ ХХХ ХХ ХХ*">
				</fieldset>

				<fieldset class="filters__fieldset">
					<legend>E-mail</legend>
					<input type="email" name="email" placeholder="Ваш Email*">
				</fieldset>

				<fieldset class="filters__fieldset">
					<legend>Доп</legend>
					<textarea>
						Опишите все ваши пожелания к заказу
					</textarea>
					<p>*Поля обязательны для заполнения</p>
				</fieldset>

				<button type="submit">Отправить заказ</button>
			</form>
		</section>
	</main>
{% endblock %}
