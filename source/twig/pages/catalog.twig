{% extends '../common/layout.twig' %}

{% set isCatalog = true %}

{% block main %}
	<main>
		<section class="products">
			<h1 class="products_heading">Каталог товаров</h1>
			<ul class="products__list">
				<li class="products__item">
					<img class="products__image" src="../img/mobile/products-1.jpg" width="260" height="195" alt="Зайчик-попрыгайчик.">
					<div class="products__item-wrapper">
						<h2 class="products__heading">Зайчик-попрыгайчик</h2>
						<p class="products__attributes">Рост 30 см, вес 200 г</p>
						<div class="products__buy">
							<p class="products__price">1 200 руб.
								<a class="products__cart-link" href="#!">
									<span class="visually-hidden">Купить</span>
								</a>
							</p>
						</div>
					</div>
				</li>
				<li class="products__item">
					<img class="products__image" src="../img/mobile/products-2.jpg" width="260" height="195" alt="Корзинка для белья.">
					<div class="products__item-wrapper">
						<h2 class="products__heading">Корзинка для белья</h2>
						<p class="products__attributes">Диаметр 15 см, высота 10 см</p>
						<div class="products__buy">
							<p class="products__price">690 руб.
								<a class="products__cart-link" href="#!">
									<span class="visually-hidden">Купить</span>
								</a>
							</p>
						</div>
					</div>
				</li>
				<li class="products__item">
					<img class="products__image" src="../img/mobile/products-3.jpg" width="260" height="195" alt="Большая корзинка для игрушек.">
					<div class="products__item-wrapper">
						<h2 class="products__heading">Большая корзинка<br>
							для игрушек</h2>
						<p class="products__attributes">Диаметр 30 см, высота 30 см</p>
						<div class="products__buy">
							<p class="products__price">1 500 руб.
								<a class="products__cart-link" href="#!">
									<span class="visually-hidden">Купить</span>
								</a>
							</p>
						</div>
					</div>
				</li>
			</ul>
		</section>

		<article class="production">
			<h2 class="production__heading">Процесс производства</h2>
			<div class="production__video">
				<button class="production__video-control" type="button" >
					<span class="visually-hidden">Проиграть видео.</span>
				</button>
			</div>
			<p class="production__text">
				По просьбам наших любимых фолловеров мы сняли для вас подробное видео о том,
																																												как появляются наши товары.
			</p>
			<a class="production__add-order" href="#">Сделать заказ</a>
		</article>
	</main>
{% endblock %}
