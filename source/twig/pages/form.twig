{% extends '../common/layout.twig' %}

{% set isMain = false %}

{% block main %}
	<main>
		<section class="filters">
			<h1 class="filters__heading heading">Вязание на заказ</h1>
			<p class="filters__text">
				Мы будем рады воплотить в жизнь<br> ваши пожелания! Заполните простую форму заказа
							и мы свяжемся с вами, чтобы уточнить детали.
			</p>
			<form class="filters__form" method="post" action="https://echo.htmlacademy.ru">
				<fieldset class="filters__fieldset">
					<legend class="filters__legend">Тип</legend>
					<p class="filters__inner">
						<input class="filters__radio" id="accessories" type="radio" name="type" value="accessories" checked>
						<label class="filters__radio-label" for="accessories">Аксессуар для интерьера</label>
					</p>
					<p class="filters__inner filters__inner--indent">
						<input class="filters__radio" id="toy" type="radio" name="type" value="child-toy">
						<label class="filters__radio-label filters__radio-label--indent" for="toy">Детская игрушка</label>
					</p>
				</fieldset>

				<fieldset class="filters__fieldset filters__fieldset--indent">
					<legend class="filters__legend filters__legend--indent">Цвет</legend>
					<p class="filters__checkbox-inner">
						<input class="filters__checkbox" id="color1" type="checkbox" name="color" value="color1" checked>
						<label class="filters__checkbox-label" for="color1">Белый</label>
					</p>
					<p class="filters__checkbox-inner">
						<input class="filters__checkbox" id="color2" type="checkbox" name="color" value="color2" checked>
						<label class="filters__checkbox-label" for="color2">Серый</label>
					</p>
					<p class="filters__checkbox-inner">
						<input class="filters__checkbox" id="color3" type="checkbox" name="color" value="color3">
						<label class="filters__checkbox-label" for="color3">Тиффани</label>
					</p>
					<p class="filters__checkbox-inner">
						<input class="filters__checkbox" id="color4" type="checkbox" name="color" value="color4">
						<label class="filters__checkbox-label" for="color4">Черный</label>
					</p>
					<p class="filters__checkbox-inner">
						<input class="filters__checkbox" id="color5" type="checkbox" name="color" value="color5">
						<label class="filters__checkbox-label" for="color5">Розовый</label>
					</p>
					<p class="filters__checkbox-inner filters__checkbox-indent">
						<input class="filters__checkbox" id="color6" type="checkbox" name="color" value="color6">
						<label class="filters__checkbox-label" for="color6">Оранжевый</label>
					</p>
				</fieldset>

				<fieldset class="filters__fieldset filters__fln">
					<legend class="filters__legend">Фио</legend>
					<label class="filters__label-fln" for="name">Имя:</label>
					<input class="filters__input-text" id="name" type="text" name="name" placeholder="Введите ваше имя*">
					<label class="filters__label-fln" for="last-name">Фамилия:</label>
					<input class="filters__input-text" id="last-name" type="text" name="last-name" placeholder="Укажите фамилию*">
					<label class="filters__label-fln" for="patronymic">Отчество:</label>
					<input class="filters__input-text" id="patronymic" type="text" name="patronymic" placeholder="Отчество, если желаете">
				</fieldset>

				<fieldset class="filters__fieldset filters__tel-wrap">
					<legend class="filters__legend filters__legend-tel">Тел</legend>
					<input class="filters__tel" type="tel" name="tel" aria-label="Введите ваш телефон." placeholder="+7 ХХХ ХХХ ХХ ХХ*">
				</fieldset>

				<fieldset class="filters__fieldset filters__email-indent email">
					<legend class="filters__legend email__indent">E-mail</legend>
					<input class="filters__email" type="email" name="email" aria-label="Введите ваш Email." placeholder="Ваш Email*">
				</fieldset>

				<fieldset class="filters__fieldset">
					<legend class="filters__legend textarea-legend">Доп</legend>
					<textarea class="filters__textarea" aria-label="Опишите все ваши пожелания к заказу.">Опишите все ваши пожелания к заказу
					</textarea>
					<p class="filters__textarea-info">*Поля обязательны для заполнения</p>
				</fieldset>

				<button class="filters__form-submit" type="submit">Отправить заказ</button>
			</form>
		</section>
	</main>
{% endblock %}
