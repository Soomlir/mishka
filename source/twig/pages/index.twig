{% extends '../common/layout.twig' %}

{% set isMain = true %}

{% block main %}
	<main>
		<section class="promo">
			<h1 class="promo__heading">Милые штуки ручной работы для дома</h1>
			<ul class="promo__products-list">
				<li class="promo__products-item">
					Предметы интерьера
				</li>
				<li class="promo__products-item">
					Детские игрушки
				</li>
			</ul>
		</section>

		<section class="product">
			<h2 class="product__heading">Вязаные корзинки</h2>
			<span class="product__special">Товар недели</span>
			<p class="product__text">
				Экологически чистая пряжа,
				ручная работа. Доступны в шести расцветках и трёх размерах.
			</p>
			<table class="product__attributes">
				<tbody>
					<tr>
						<th scope="col">Цвет:</th>
						<th scope="col">тиффани/серый</th>
					</tr>
					<tr>
						<td>Диаметр:</td>
						<td>25 см</td>
					</tr>
					<tr>
						<td>Высота:</td>
						<td>15 см</td>
					</tr>
				</tbody>
			</table>
			<img class="product__image" src="img/mobile/triple-set-mobile.jpg" width="260" height="315"
				alt="Вязанные корзинки ручной работы.">
			<p class="product__price">Цена: 990 руб.</p>
			<a class="product__order">Заказать</a>
		</section>

		<section class="about-us">
			<h2 class="about-us__heading">Коротко о нас:</h2>
			<ul class="about-us__list">
				<li class="about-us__item">Экологически чистые материалы</li>
				<li class="about-us__item">Скандинавский стиль по российской цене</li>
				<li class="about-us__item">Увеличивает лайки на фотографиях</li>
				<li class="about-us__item">Связано вручную c любовью и умилением</li>
				<li class="about-us__item">Поддержка отечественного производителя</li>
				<li class="about-us__item">Поставляется в подарочной упаковке</li>
			</ul>
		</section>

		<section class="reviews">
			<h2 class="reviews__heading">Отзывы</h2>
			<ul class="reviews__list">
				<li class="reviews__item">
					<p class="reviews__text">
						Я молодая мама, но всё равно фотографии не набирали и близко такого количества лайков, как
						у популярных инстамамочек. В отчаянии, я накупила аксессуаров и игрушек в Мишке,
						и мои фотографии сразу стали более стильными, а также набирают больше лайков!
					</p>
					<p class="reviews__author">
						Анастасия Красильникова
						<span class="reviews__author-contact">@misssssiskras</span>
					</p>
				</li>
			</ul>
			<button class="reviews__prev" type="button">Предыдущий отзыв</button>
			<button class="reviews__next" type="button">Следующий отзыв</button>
			<a class="reviews__new">Написать</a>
		</section>

		<section class="contacts">
			<h2 class="contacts__heading">Наши контакты</h2>
			<table class="contacts__table">
				<tbody>
					<tr>
						<td>e-mail:</td>
						<td>info@mimimishkashop.ru</td>
					</tr>
					<tr>
						<td>адрес:</td>
						<td>г. Санкт-Петербург<br>ул. Большая Конюшенная<br>д. 19/8, офис 101</td>
					</tr>
				</tbody>
			</table>
		</section>

		<section class="address">
			<h2 class="address__heading">Наше расположение на карте</h2>
			<img class="address__map" src="img/mobile/map-mobile.jpg" width="320" height="456" alt="Наше расположение на карте.">
			<a class="address__link">Напишите нам</a>
		</section>
	</main>
{% endblock %}
